rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // entries: public read needed for standings + my-picks; users can write their own doc
    match /entries/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // teams: public read for picks page; no public write
    match /teams/{teamId} {
      allow read: if true;
      allow write: if false;
    }

    // games: public read for picks + standings; no public write
    match /games/{gameId} {
      allow read: if true;
      allow write: if false;
    }

    // settings: public read (registration status); no public write
    match /settings/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // config: never expose admin auth config to client
    match /config/{docId} {
      allow read, write: if false;
    }
  }
}
